Table users {
  id bigint [pk, increment]
  username varchar [not null, unique]
  pwd varchar [not null]
  created_at timestamp [default: `now()`]
  updated_at timestamp
}

Table households {
  id bigint [pk, increment]
  name varchar [not null]
  created_by bigint [not null]
  created_at timestamp [default: `now()`]
  updated_at timestamp
}

Table household_members {
  user_id bigint [not null]
  household_id bigint [not null]
  role varchar //[default: 'member']  -- admin, member, child
  joined_at timestamp [default: `now()`]

  indexes {
    (user_id, household_id) [pk]
  }
}

Table groceries {
  id int [pk, increment]
  product varchar [not null]
  brand varchar
  amount int
  unit varchar
  store varchar
  household_id int [not null]
  created_at timestamp [default: `now()`]
  updated_at timestamp
}

Table chores {
  id int [pk, increment]
  title varchar [not null]
  deadline timestamp
  repeats int
  household_id int [not null]
  created_at timestamp [default: `now()`]
  updated_at timestamp
}

Table recipes {
  id int [pk, increment]
  title varchar [not null]
  img_url varchar
  link varchar
  household_id int [not null]
  created_at timestamp [default: `now()`]
  updated_at timestamp
}

Ref: household_members.user_id > users.id
Ref: household_members.household_id > households.id

Ref: households.created_by > users.id

Ref: groceries.household_id > households.id
Ref: chores.household_id > households.id
Ref: recipes.household_id > households.id
